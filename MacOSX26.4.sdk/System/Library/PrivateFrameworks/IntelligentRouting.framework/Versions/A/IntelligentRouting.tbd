                       _IRMediaEventTypeToString, _IRServicePackageString, _IRSessionAvailableNotification, 
                       _IRSetupLogging, _kIREventNameAppleTVControl, _kIREventNameHome, 
                       _kIREventNameMedia, _kIRServiceLogPrefixKey ]

--- !tapi-tbd
tbd-version:     4
targets:         [ x86_64-macos, arm64e-macos ]
install-name:    '/System/Library/PrivateFrameworks/PIRGeoProtos.framework/Versions/A/PIRGeoProtos'
current-version: 2418.4.13
allowable-clients:
  - targets:         [ x86_64-macos, arm64e-macos ]
    clients:         [ SpotlightKnowledgeDaemon, cslinguistics, spotlightknowledged ]
exports:
  - targets:         [ x86_64-macos, arm64e-macos ]
    symbols:         [ _PIRAspireResultReadFrom, _PIRGeoListSnippetReadFrom, _PIRGeoPoiReadFrom, 
                       _PIRGeoProtosVersionNumber, _PIRGeoProtosVersionString, _PIRMapRegionReadFrom, 
                       _PIRPointReadFrom, _PIRStructuredAddressReadFrom, _PIRTimezoneReadFrom ]
    objc-classes:    [ PIRAspireResult, PIRGeoListSnippet, PIRGeoPoi, PIRMapRegion, 
                       PIRPoint, PIRStructuredAddress, PIRTimezone ]
    objc-ivars:      [ PIRAspireResult._compressedGeoList, PIRAspireResult._geoList, 
                       PIRGeoListSnippet._pois, PIRGeoPoi._address, PIRGeoPoi._administrativeAreaEncryptedMuid, 
                       PIRGeoPoi._apolloId, PIRGeoPoi._boundingBox, PIRGeoPoi._countryEncryptedMuid, 
                       PIRGeoPoi._encryptedMuid, PIRGeoPoi._has, PIRGeoPoi._modernPrimaryCategoryId, 
                       PIRGeoPoi._popularityCartoScore, PIRGeoPoi._prefGeocode, PIRGeoPoi._prefName, 
                       PIRGeoPoi._subAdministrativeAreaEncryptedMuid, PIRGeoPoi._timezone, 
                       PIRGeoPoi._title, PIRGeoPoi._zioId, PIRMapRegion._eastLng, 
                       PIRMapRegion._has, PIRMapRegion._northLat, PIRMapRegion._southLat, 
                       PIRMapRegion._westLng, PIRPoint._has, PIRPoint._lat, PIRPoint._lng, 
                       PIRStructuredAddress._administrativeArea, PIRStructuredAddress._administrativeAreaCode, 
                       PIRStructuredAddress._country, PIRStructuredAddress._countryCode, 
                       PIRStructuredAddress._dependentLocalitys, PIRStructuredAddress._locality, 
                       PIRStructuredAddress._postCode, PIRStructuredAddress._subAdministrativeArea, 
                       PIRStructuredAddress._subThoroughfare, PIRStructuredAddress._thoroughfare, 
                       PIRTimezone._identifier ]
...

--- !tapi-tbd
tbd-version:     4
targets:         [ x86_64-macos, x86_64-maccatalyst, arm64e-macos, arm64e-maccatalyst ]
install-name:    '/System/Library/PrivateFrameworks/MicroLocation.framework/Versions/A/MicroLocation'
exports:
  - targets:         [ x86_64-macos, x86_64-maccatalyst, arm64e-macos, arm64e-maccatalyst ]
    symbols:         [ _ULConfidenceReasonToString, _ULConfidenceToString, _ULConnectionAvailableNotification, 
                       _ULContextLayerRoomClassNameBathroom, _ULContextLayerRoomClassNameBedroom, 
                       _ULContextLayerRoomClassNameChildRoom, _ULContextLayerRoomClassNameCorridorHallway, 
                       _ULContextLayerRoomClassNameDiningRoom, _ULContextLayerRoomClassNameGameRoom, 
                       _ULContextLayerRoomClassNameHomeGarage, _ULContextLayerRoomClassNameHomeOffice, 
                       _ULContextLayerRoomClassNameIndoors, _ULContextLayerRoomClassNameKitchen, 
                       _ULContextLayerRoomClassNameLaundry, _ULContextLayerRoomClassNameLivingRoom, 
                       _ULContextLayerRoomClassNameOffice, _ULContextLayerRoomClassNameStaircase, 
                       _ULContextLayerRoomClassNameUnknown, _ULContextLayerTypeCoLocation, 
                       _ULContextLayerTypeFocusMode, _ULContextLayerTypeHomeKitUserInteraction, 
                       _ULContextLayerTypeIRAppleTVControl, _ULContextLayerTypeIRControlCenter, 
                       _ULContextLayerTypeIRHome, _ULContextLayerTypeIRHostTestsAppleTVControl, 
                       _ULContextLayerTypeIRHostTestsHome, _ULContextLayerTypeIRHostTestsMedia, 
                       _ULContextLayerTypeIRMedia, _ULContextLayerTypeIRMediaRemote, 
                       _ULContextLayerTypeIRMusic, _ULContextLayerTypeIRNeighborhoodActivity, 
                       _ULContextLayerTypeIRRoutePickerView, _ULContextLayerTypeIRRoverApp, 
                       _ULContextLayerTypeIRTVRemote, _ULContextLayerTypeIRTelephonyUtilities, 
                       _ULContextLayerTypeMiLoDebug, _ULContextLayerTypeMiLoHostTests, 
                       _ULContextLayerTypeMiLoPlaceholderApp, _ULContextLayerTypePilApp, 
                       _ULContextLayerTypeRoomClass, _ULContextLayerTypeUnknown, 
                       _ULContextLayerTypeWiFi, _ULCoordinatesNotAvailable, _ULDeviceClassToString, 
                       _ULLocationTypeToString, _ULMapItemTypeClientGenerated, _ULMapItemTypeMiLoGenerated, 
                       _ULPeripheralDebugTaskToString, _ULPredictionsUpdateTypeToString, 
                       _ULRssiNotAvailable, _ULServiceQualityReasonToString, _ULServiceQualityToString, 
                       _ULServiceStateToString, _ULServiceSuspendReasonToString, 
                       _ULServiceTypeToString, _ULSubmapIndexNotAvailable, _ULYawNotAvailable ]
    objc-classes:    [ ULAccessibilitySessionFetchOptions, ULConfidenceReason, ULConfiguration, 
                       ULConnection, ULContextLayerUtilities, ULCoordinate, ULCustomLoiConfiguration, 
                       ULDevicePredictionContext, ULFingerprintMetaInfo, ULHomeSlamModelData, 
                       ULLabel, ULLabelHomeKitUserInteraction, ULLabelWiFi, ULLocationOfInterest, 
                       ULLocationType, ULMap, ULMapItem, ULMapPoint, ULMapROI, ULMapTrajectoryPoint, 
                       ULPlace, ULPrediction, ULPredictionContext, ULServiceDescriptor, 
                       ULServiceMetaInfo, ULServiceQualityInfo, ULServiceQualityReason, 
                       ULServiceStatus, ULServiceSuspendReason, ULUpdateConfiguration, 
                       ULXPCProtocols ]
...

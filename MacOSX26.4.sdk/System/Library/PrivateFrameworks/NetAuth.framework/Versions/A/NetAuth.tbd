--- !tapi-tbd
tbd-version:     4
targets:         [ x86_64-macos, x86_64-maccatalyst, arm64e-macos, arm64e-maccatalyst ]
install-name:    '/System/Library/PrivateFrameworks/NetAuth.framework/Versions/A/NetAuth'
exports:
  - targets:         [ x86_64-macos, x86_64-maccatalyst, arm64e-macos, arm64e-maccatalyst ]
    symbols:         [ _NAAccountUpdated, _NAAuthCredentialsClose, _NAAuthCredentialsCreate, 
                       _NAAuthCredentialsGetCredentials, _NAAuthCredentialsGetTypeID, 
                       _NAAuthCredentialsSetOptions, _NACancelConnectToServerAsync, 
                       _NAChangePasswordClose, _NAChangePasswordCreate, _NAChangePasswordGetCredentials, 
                       _NAChangePasswordGetTypeID, _NAChangePasswordSetOptions, _NACloseSessionAsync, 
                       _NACloseSessionSync, _NAConnectToServerAsync, _NAConnectToServerCancel, 
                       _NAConnectToServerStart, _NAConnectToServerSync, _NAEnumerateSharesAsync, 
                       _NAEnumerateSharesSync, _NAErrorDialogCreate, _NAErrorDialogDisplayErrorInfo, 
                       _NAErrorDialogGetTypeID, _NAGetCredentialsCloseSessionAsync, 
                       _NAGetCredentialsOpenSessionAsync, _NAGetCredentialsOpenSessionInModeAsync, 
                       _NAGetCredentialsReportErrorAsync, _NAGetCredentialsReportErrorInModeAsync, 
                       _NAGetCredentialsShowProgressAsync, _NAGetCredentialsShowProgressInModeAsync, 
                       _NAGetQueue, _NAMountAsync, _NAMountSync, _NAOpenSessionAsync, 
                       _NAOpenSessionSync, _NAProgressClose, _NAProgressCreate, _NAProgressDisplay, 
                       _NAProgressGetTypeID, _NAProgressSetOptions, _NAProgressUpdate, 
                       _NASharePickerClose, _NASharePickerCreate, _NASharePickerGetSelectedShares, 
                       _NASharePickerGetTypeID, _NASharePickerSetOptions, _NAShouldConnectCreate, 
                       _NAShouldConnectDisplayWithOptions, _NAShouldConnectGetTypeID, 
                       _NAUpdateAccount, _NAVerifyMountPoint, _NAVolumePasswordClose, 
                       _NAVolumePasswordCreate, _NAVolumePasswordGetCredentials, 
                       _NAVolumePasswordGetTypeID, _NAVolumePasswordSetOptions, __NACopyDebugDesc, 
                       __NACopyFormattingDesc, __NACopyGenericCredentials, __NACopyInternetCredentials, 
                       __NAEqual, __NAFinalize, __NAGetKnownServerMarker, __NAHash, 
                       __NARuntimeCreateInstance, __NASetGenericCredentials, __NASetInternetCredentials, 
                       __NASetKnownServerMarker ]
...
